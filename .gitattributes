# Normalize all text files to LF line endings.
# Overrides core.autocrlf on Windows so that rustfmt (newline_style = "Unix")
# and cargo fmt --check --all always see LF on every platform.
* text=auto eol=lf

# Rust source and configuration – always LF
*.rs   text eol=lf
*.toml text eol=lf

# YAML / JSON
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
